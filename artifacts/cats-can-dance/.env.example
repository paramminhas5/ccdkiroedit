# ─── Cats Can Dance — Frontend Environment Variables ─────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Clerk Auth (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_PROXY_URL=                          # Optional: only needed for Replit/custom domain

# ── Supabase (required) ───────────────────────────────────────────────────────
# Anon key is safe to expose (RLS protects data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service key for server-side proxy routes (NEVER expose to browser)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin Panel ───────────────────────────────────────────────────────────────
# Must match ADMIN_PASSWORD in the API server
ADMIN_PASSWORD=your_secure_password_here

# ── API Server ────────────────────────────────────────────────────────────────
# URL of the Express API server (used by SSR pages)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Shopify (required for shop) ───────────────────────────────────────────────
# Get from: Shopify Admin → Apps → Develop apps → Your app → Storefront API
# The token and domain are currently hardcoded in src/lib/shopify.ts
# TODO: move these to env vars
# SHOPIFY_STOREFRONT_TOKEN=your_storefront_api_token
# SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
