# ─── Cats Can Dance — API Server Environment Variables ───────────────────────
# Copy this file to .env and fill in your values.

# ── Database (required) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── Clerk Auth (required) ─────────────────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_PROXY_URL=                          # Optional

# ── Admin ─────────────────────────────────────────────────────────────────────
# Must match ADMIN_PASSWORD in the frontend
ADMIN_PASSWORD=your_secure_password_here

# ── YouTube (optional — enables Videos page sync) ────────────────────────────
# Get from: console.cloud.google.com → YouTube Data API v3
YOUTUBE_API_KEY=AIzaSy...

# ── Instagram (optional — enables Instagram feed) ────────────────────────────
# Long-lived token from Meta Graph API (expires every 60 days, must refresh)
INSTAGRAM_ACCESS_TOKEN=IGQVJXb...

# ── Firecrawl (optional — enables artist profile enrichment) ─────────────────
# Get from: firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# ── OpenAI (optional — enables AI bio generation for enrichment) ─────────────
OPENAI_API_KEY=sk-...

# ── Email / Resend (optional — enables OTP emails, RSVP confirmations) ───────
# Get from: resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=hello@catscandance.com

# ── Stripe (coming soon — for ticketing) ─────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
